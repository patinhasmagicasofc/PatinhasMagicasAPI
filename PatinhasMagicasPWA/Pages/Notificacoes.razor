@page "/notificacoes"
@inject JwtService JwtService
@inject PushNotificationService PushNotificationService
@inject DeviceFeedbackService DeviceFeedbackService

<main>
    <section class="notification-hero">
        <p class="title">Notificações</p>
        <p class="subtitle">Gerencie push e recursos do dispositivo em um único lugar.</p>
    </section>

    <section class="notification-card">
        <p class="section-title">Push</p>
        <p class="section-text">Ative para receber confirmações de agendamento e avisos importantes.</p>

        @if (!string.IsNullOrWhiteSpace(pushMessage))
        {
            <p class="feedback">@pushMessage</p>
        }

        <button class="primary" @onclick="AtivarPushAsync" disabled="@loading">
            <span class="material-symbols-outlined">notifications_active</span>
            Ativar notificações
        </button>

        <button class="secondary" @onclick="EnviarTestePushAsync" disabled="@loading">
            <span class="material-symbols-outlined">send</span>
            Enviar teste push
        </button>
    </section>

    <section class="notification-card">
        <p class="section-title">Vibração</p>
        <p class="section-text">Use vibração curta em confirmações, aviso de erro ou feedback de ação no celular.</p>

        @if (!string.IsNullOrWhiteSpace(deviceMessage))
        {
            <p class="feedback">@deviceMessage</p>
        }

        <div class="button-group">
            <button class="primary" @onclick="TestarVibracaoSucessoAsync" disabled="@(!deviceSupported)">
                <span class="material-symbols-outlined">done_all</span>
                Testar sucesso
            </button>

            <button class="secondary" @onclick="TestarVibracaoAvisoAsync" disabled="@(!deviceSupported)">
                <span class="material-symbols-outlined">warning</span>
                Testar aviso
            </button>
        </div>

        <p class="helper-text">Vibração disponível: @(deviceSupported ? "Sim" : "Não")</p>
    </section>

    <section class="notification-card">
        <p class="section-title">Sugestão</p>
        <p class="section-text">Vale usar vibração em eventos curtos, como salvar foto do animal, confirmar agendamento ou falha importante. Evite vibrar em toda navegação para não cansar o usuário.</p>
    </section>
</main>

<MenuInferior />

@code {
    private string pushMessage = string.Empty;
    private string deviceMessage = string.Empty;
    private bool loading;
    private int? usuarioId;
    private bool deviceSupported;

    protected override async Task OnInitializedAsync()
    {
        var userIdString = await JwtService.GetUserIdAsync();
        usuarioId = int.TryParse(userIdString, out var userId) ? userId : null;

        try
        {
            deviceSupported = await DeviceFeedbackService.IsSupportedAsync();
        }
        catch
        {
            deviceSupported = false;
        }
    }

    private async Task AtivarPushAsync()
    {
        if (!usuarioId.HasValue)
        {
            pushMessage = "Usuário não identificado.";
            await DeviceFeedbackService.VibrateWarningAsync();
            return;
        }

        loading = true;

        try
        {
            var result = await PushNotificationService.SubscribeAsync(usuarioId.Value);
            pushMessage = result.Message;

            if (result.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                return;
            }

            await DeviceFeedbackService.VibrateWarningAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task EnviarTestePushAsync()
    {
        if (!usuarioId.HasValue)
        {
            pushMessage = "Usuário não identificado.";
            await DeviceFeedbackService.VibrateWarningAsync();
            return;
        }

        loading = true;

        try
        {
            var result = await PushNotificationService.SendTestAsync(usuarioId.Value);
            pushMessage = result.Message;

            if (result.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                return;
            }

            await DeviceFeedbackService.VibrateWarningAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task TestarVibracaoSucessoAsync()
    {
        var supported = await DeviceFeedbackService.IsSupportedAsync();
        deviceMessage = supported
            ? "Feedback de sucesso disparado."
            : "Seu dispositivo ou navegador não oferece suporte a vibração.";

        if (supported)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
        }
    }

    private async Task TestarVibracaoAvisoAsync()
    {
        var supported = await DeviceFeedbackService.IsSupportedAsync();
        deviceMessage = supported
            ? "Feedback de aviso disparado."
            : "Seu dispositivo ou navegador não oferece suporte a vibração.";

        if (supported)
        {
            await DeviceFeedbackService.VibrateWarningAsync();
        }
    }
}
