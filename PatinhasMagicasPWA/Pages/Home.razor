@page "/home"

<PageTitle>Home</PageTitle>

@* <button @onclick="FazerLogin">Login</button>
<button @onclick="Cadastrar">Cadastresse</button> *@

<main>
    <section id="hero-section">
        <div class="img-hero">
            <img src="./img/hero-pets.jpg" alt="Pets" />
        </div>
        <div class="info-hero">
            <ul>
                <li class="title">
                    <p>Tudo para seu</p>
                    <p>Melhor Amigo!</p>
                </li>
                <li class="info">
                    <p>
                        Desde rações premium até o banho mais relaxante da cidade.
                        Encontre tudo o que o seu pet precisa em um só lugar.
                    </p>
                </li>
            </ul>
            <div class="btn-hero">
                <button>Ver Produtos</button>
                <a href="#">Nossos Serviços →</a>
            </div>
        </div>
    </section>

    <section id="feature-section">
        <div class="cards-details">
            <div class="card-details">
                <div class="icon-card">
                    <span class="material-symbols-outlined">local_shipping</span>
                </div>
                <div class="details-title">
                    <p>Entrega Rápida</p>
                </div>
            </div>

            <div class="card-details">
                <div class="icon-card">
                    <span class="material-symbols-outlined">bathtub</span>
                </div>
                <div class="details-title">
                    <p>Banho & Tosa</p>
                </div>
            </div>

            <div class="card-details">
                <div class="icon-card">
                    <span class="material-symbols-outlined">storefront</span>
                </div>
                <div class="details-title">
                    <p>Pet Shop Completo</p>
                </div>
            </div>

            <div class="card-details">
                <div class="icon-card">
                    <span class="material-symbols-outlined">favorite</span>
                </div>
                <div class="details-title">
                    <p>Atendimento Especial</p>
                </div>
            </div>
        </div>
    </section>

    <section id="product-section">
        <div class="title-product">
            <ul>
                <li>
                    <p>Nossos Produtos</p>
                    <p>As melhores ofertas para seu pet</p>
                </li>
            </ul>
        </div>

        <div class="card-product">
            <div class="img-card">
                <img src="./img/product-food.jpg" alt="Ração Patinhas Mágicas" />
            </div>
            <div class="info-card">
                <ul>
                    <li>
                        <!-- Filtrar por categoria -->
                        <p>Rações</p>
                        <p>As melhores marcas</p>
                    </li>
                </ul>
            </div>
            <div class="btn-card">
                <button>Ver Mais</button>
            </div>
        </div>

        <div class="card-product">
            <div class="img-card">
                <img src="./img/product-accessories.jpg"
                     alt="Ração Patinhas Mágicas" />
            </div>
            <div class="info-card">
                <ul>
                    <li>
                        <p>Acessórios</p>
                        <p>Estilo e conforto</p>
                    </li>
                </ul>
            </div>
            <div class="btn-card"><button>Ver Mais</button></div>
        </div>

        <div class="card-product">
            <div class="img-card">
                <img src="./img/product-hygiene.jpg" alt="Ração Patinhas Mágicas" />
            </div>
            <div class="info-card">
                <ul>
                    <li>
                        <p>Higiene</p>
                        <p>Cuidado completo</p>
                    </li>
                </ul>
            </div>
            <div class="btn-card"><button>Ver Mais</button></div>
        </div>

        <div class="card-product">
            <div class="img-card">
                <img src="./img/product-toys.jpg" alt="Ração Patinhas Mágicas" />
            </div>
            <div class="info-card">
                <ul>
                    <li>
                        <p>Brinquedos</p>
                        <p>Diversão garantida</p>
                    </li>
                </ul>
            </div>
            <div class="btn-card"><button>Ver Mais</button></div>
        </div>
    </section>

    <section id="service-section">
        <div class="title-services">
            <ul>
                <li>
                    <p>SERVIÇOS</p>
                    <p>Cuidado completo para cada fase do seu pet</p>
                    <p>
                        Da rotina de higiene ao acompanhamento profissional, reunimos
                        tudo em um só lugar com atendimento humanizado.
                    </p>
                </li>
            </ul>
        </div>

        <div class="card-service">
            <div class="icon-service">
                <span class="material-symbols-outlined">bathtub</span>
            </div>
            <div class="title-service">
                <ul>
                    <li>
                        <p>Banho & Tosa</p>
                        <p>
                            Higiene, hidratação e cuidado completo para deixar seu pet
                            limpo, cheiroso e confortável.
                        </p>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card-service">
            <div class="icon-service">
                <span class="material-symbols-outlined">neurology</span>
            </div>
            <div class="title-service">
                <ul>
                    <li>
                        <p>Adestramento e Comportamento</p>
                        <p>
                            Treinos personalizados para melhorar a convivência, obediência
                            e bem-estar do seu melhor amigo.
                        </p>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card-service">
            <div class="icon-service">
                <span class="material-symbols-outlined">health_and_safety</span>
            </div>
            <div class="title-service">
                <ul>
                    <li>
                        <p>Atendimento Veterinario</p>
                        <p>
                            Acompanhamento com atenção profissional para prevenção,
                            avaliação e orientação de saúde.
                        </p>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card-service">
            <div class="icon-service">
                <span class="material-symbols-outlined">verified</span>
            </div>
            <div class="title-service">
                <ul>
                    <li>
                        <p>Transporte Pet Seguro</p>
                        <p>
                            Leva e traz com conforto e cuidado para consultas, banho,
                            creche e outros compromissos.
                        </p>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card-service">
            <div class="icon-service">
                <span class="material-symbols-outlined">apartment</span>
            </div>
            <div class="title-service">
                <ul>
                    <li>
                        <p>Hospedagem e Creche para Animais de Estimação</p>
                        <p>
                            Espaço seguro e acolhedor para dias de diversão, descanso e
                            rotina assistida.
                        </p>
                    </li>
                </ul>
            </div>
        </div>
    </section>

    <section id="banner-section">
        <div class="background-banner">
            <div class="title-banner">
                <ul>
                    <li>
                        <p>Banho & Tosa – Cuide do seu pet com todo carinho</p>
                        <p>
                            Profissionais qualificados e produtos de primeira linha para
                            deixar seu amigo cheiroso e feliz.
                        </p>
                    </li>
                </ul>
            </div>
            <div class="btn-banner">
                <button>Agende um Horário</button>
            </div>
            <div class="img-banner">
                <img src="./img/grooming-dog.jpg" alt="Banho & Tosa" />
            </div>
        </div>
    </section>
      
    <!-- Sera adicionado posteriormente -->
    <!-- <section id="testimonials-section"></section> -->

    <section id="contact-section">
        <div class="container-contact">
            <div class="info-contact">
                <div class="title">
                    <ul>
                        <li>
                            <p>FALE CONOSCO</p>
                            <p>
                                Seu pet merece um atendimento acolhedor do começo ao fim
                            </p>
                            <p>
                                Tire dúvidas, peça um agendamento ou solicite transporte
                                seguro. Nossa equipe responde rapidinho.
                            </p>
                        </li>
                    </ul>
                </div>

                <div class="card-contact">
                    <div class="icon">
                        <span class="material-symbols-outlined">call</span>
                    </div>
                    <div class="info">
                        <ul>
                            <li>
                                <p>Telefone</p>
                                <p>(11) 96215-2155</p>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="card-contact">
                    <div class="icon">
                        <span class="material-symbols-outlined">chat_bubble</span>
                    </div>
                    <div class="info">
                        <ul>
                            <li>
                                <p>WhatsApp</p>
                                <p>(11) 96545-5481</p>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="card-contact">
                    <div class="icon">
                        <span class="material-symbols-outlined">place</span>
                    </div>
                    <div class="info">
                        <ul>
                            <li>
                                <p>Endereço</p>
                                <p>Rua Ficticía, 899 - Bairro da Imaginação | CEP: 008185-689 - São Paulo/SP</p>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="card-contact">
                    <div class="icon">
                        <span class="material-symbols-outlined">access_time</span>
                    </div>
                    <div class="info">
                        <ul>
                            <li>
                                <p>Horário</p>
                                <p>Seg a Sáb - 8h às 19h</p>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>

            <div class="form-contact">
                <form>
                    <ul>
                        <li>
                            <label for="name">Nome</label>
                            <input type="text"
                                   id="name"
                                   name="name"
                                   placeholder="Seu nome"
                                   required="" />
                        </li>
                        <li>
                            <label for="email">E-mail</label>
                            <input type="email"
                                   id="email"
                                   name="email"
                                   placeholder="seu@email.com"
                                   required="" />
                        </li>
                        <li>
                            <label for="phone">Telefone</label>
                            <input type="tel"
                                   id="phone"
                                   name="phone"
                                   placeholder="(99) 99999-9999"
                                   required="" />
                        </li>
                        <li>
                            <label for="message">Mensagem</label>
                            <textarea id="message"
                                      name="message"
                                      rows="5"
                                      placeholder="Escreva sua mensagem..."
                                      required=""></textarea>
                        </li>
                    </ul>

                    <div class="btn-contact">
                        <button type="submit">Enviar mensagem</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

</main>

