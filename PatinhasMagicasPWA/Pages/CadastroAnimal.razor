@page "/CadastroAnimal"
@inject NavigationManager Navigation
@inject AnimalService AnimalService
@inject EspecieService EspecieService
@inject TamanhoAnimalService TamanhoAnimalService
<main class="cadastro-animal-page" id="cadastro-animal">
    <EditForm class="card-form"
              Model="@animal"
              OnValidSubmit="Cadastrar">
        <DataAnnotationsValidator />
        <ul>
            <li>
                <p class="title">Cadastro de Animal</p>
            </li>
        </ul>
        <div class="photo-card">
            <p class="label">Foto do animal</p>
            <img class="animal-photo-preview"
                 src="caminho-da-imagem.jpg"
                 alt="Foto do animal" />
            <div class="animal-photo-placeholder">
                <span class="material-symbols-outlined">pets</span>
                <p>Nenhuma foto cadastrada.</p>
            </div>
            <p class="photo-note">A foto é opcional. Se quiser, você pode cadastrar ou trocar depois.</p>
            <input type="file"
                   accept="image/*"
                   class="photo-input" />
            <button type="button" class="photo-remove">
                Remover foto
            </button>
        </div>
        <div class="field">
            <ul>
                <li>
                    <p class="label">Nome *</p>
                    <InputText @bind-Value="animal.Nome"
                               class="input-real"
                               placeholder="Digite o nome do animal"
                               required />
                    <ValidationMessage class="text-danger" For="@(() => animal.Nome)" />
                </li>
            </ul>
        </div>
        <div class="field">
            <ul>
                <li>
                    <p class="label">Espécie *</p>
                    <InputSelect @bind-Value="animal.EspecieId"
                                 class="input-select"
                                 required>
                        <option value="">Selecione uma espécie</option>
                        @if (especies.Count == 0)
                        {
                            <option disabled>Não há opções de espécies disponíveis</option>
                        }
                        else
                        {
                            @foreach (var especie in especies)
                            {
                                <option value="@especie.Id">
                                    @especie.Nome
                                </option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage class="text-danger" For="@(() => animal.EspecieId)" />
                </li>
            </ul>
        </div>
        <div class="field">
            <ul>
                <li>
                    <p class="label">Raça</p>
                    <InputText @bind-Value="animal.Raca"
                               class="input-real"
                               placeholder="Ex: Poodle, Siam?s..." />
                    <ValidationMessage class="text-danger" For="@(() => animal.Raca)" />
                </li>
            </ul>
        </div>
        <div class="field">
            <ul>
                <li>
                    <p class="label">Idade</p>
                    <InputNumber @bind-Value="animal.Idade"
                                 class="input-real"
                                 placeholder="0"
                                 min="0" />
                    <ValidationMessage class="text-danger" For="@(() => animal.Idade)" />
                </li>
            </ul>
        </div>
        <div class="field">
            <ul>
                <li>
                    <p class="label">Tamanho *</p>
                    <InputSelect @bind-Value="animal.TamanhoAnimalId"
                                 class="input-select"
                                 required>
                        <option value="">Selecione um tamanho</option>
                        @if (tamanhoAnimals.Count == 0)
                        {
                            <option disabled>Não há opções de tamanho disponíveis</option>
                        }
                        else
                        {
                            @foreach (var tamanho in tamanhoAnimals)
                            {
                                <option value="@tamanho.Id">
                                    @tamanho.Nome
                                </option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage class="text-danger" For="@(() => animal.TamanhoAnimalId)" />
                </li>
            </ul>
        </div>
        <div class="actions">
            <button type="button" class="cancel">
                Cancelar cadastro
            </button>
            <button type="submit" class="btn-primary">
                Cadastrar Animal
            </button>
        </div>
    </EditForm>
</main>

@code
{
    AnimalDTO animal = new();

    List<TamanhoAnimalDTO> tamanhoAnimals = new();

    List<EspecieOutputDTO> especies = new();

    protected override async Task OnInitializedAsync()
    {
        tamanhoAnimals = await TamanhoAnimalService.GetAllAsync();

        especies = await EspecieService.GetAllAsync();
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/home");
    }

    private async Task Cadastrar()
    {
        var result = await AnimalService.Cadastrar(animal);
        if (result)
        {
            Navigation.NavigateTo("/MeusAnimais");
        }
    }
}
