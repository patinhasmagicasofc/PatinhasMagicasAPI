@page "/Animal/{id:int}"
@inject AnimalService AnimalService
@inject EspecieService EspecieService
@inject TamanhoAnimalService TamanhoAnimalService
@inject NavigationManager Navigation
@inject DeviceFeedbackService DeviceFeedbackService

<main>
    <EditForm class="card-form" Model="@animal" OnSubmit="SalvarAlteracoes">
        <ul>
            <li>
                <p class="title">Editar Animal</p>
            </li>
        </ul>

        <p class="helper-text">Os dados do animal carregam bloqueados. Clique em editar para liberar os campos com * obrigatorios.</p>

        <div class="photo-card">
            <p class="label">Foto do animal</p>

            @if (!string.IsNullOrWhiteSpace(animal.FotoDataUrl))
            {
                <img class="animal-photo-preview" src="@animal.FotoDataUrl" alt="Foto do animal" />
            }
            else
            {
                <div class="animal-photo-placeholder">
                    <span class="material-symbols-outlined">pets</span>
                    <p>Nenhuma foto cadastrada.</p>
                </div>
            }

            <p class="photo-note">A foto e opcional. Se quiser, voce pode cadastrar ou trocar depois.</p>

            <InputFile OnChange="SelecionarFotoAsync"
                       accept="image/*"
                       class="photo-input"
                       disabled="@FormularioBloqueado" />

            @if (!string.IsNullOrWhiteSpace(animal.FotoDataUrl))
            {
                <button type="button" class="photo-remove" @onclick="RemoverFotoAsync" disabled="@FormularioBloqueado">Remover foto</button>
            }
        </div>

        <div class="field">
            <ul>
                <li>
                    <p class="label">Nome *</p>
                    <InputText type="text"
                               class="input-real"
                               placeholder="Digite o nome do animal"
                               @bind-Value="animal.Nome"
                               disabled="@FormularioBloqueado" />
                    @if (ExibirErroNome)
                    {
                        <span class="validation-message">Informe o nome do animal.</span>
                    }
                </li>
            </ul>
        </div>

        <div class="field">
            <ul>
                <li>
                    <p class="label">Especie *</p>
                    <InputSelect class="input-select" @bind-Value="animal.EspecieId" disabled="@FormularioBloqueado">
                        <option value="0">Selecione</option>
                        @foreach (var especie in especies)
                        {
                            <option value="@especie.Id">@especie.Nome</option>
                        }
                    </InputSelect>
                    @if (ExibirErroEspecie)
                    {
                        <span class="validation-message">Selecione uma especie.</span>
                    }
                </li>
            </ul>
        </div>

        <div class="field">
            <ul>
                <li>
                    <p class="label">Raca</p>
                    <InputText type="text"
                               class="input-real"
                               placeholder="Ex: Poodle, Siames..."
                               @bind-Value="animal.Raca"
                               disabled="@FormularioBloqueado" />
                </li>
            </ul>
        </div>

        <div class="field">
            <ul>
                <li>
                    <p class="label">Idade</p>
                    <InputNumber class="input-real"
                                 placeholder="0"
                                 min="0"
                                 @bind-Value="animal.Idade"
                                 disabled="@FormularioBloqueado" />
                </li>
            </ul>
        </div>

        <div class="field">
            <ul>
                <li>
                    <p class="label">Tamanho *</p>
                    <InputSelect class="input-select" @bind-Value="animal.TamanhoAnimalId" disabled="@FormularioBloqueado">
                        <option value="0">Selecione</option>
                        @foreach (var tamanho in tamanhos)
                        {
                            <option value="@tamanho.Id">@tamanho.Nome</option>
                        }
                    </InputSelect>
                    @if (ExibirErroTamanho)
                    {
                        <span class="validation-message">Selecione o tamanho do animal.</span>
                    }
                </li>
            </ul>
        </div>

        @if (!string.IsNullOrWhiteSpace(mensagemErro))
        {
            <p class="validation-message form-message">@mensagemErro</p>
        }

        <div class="actions">
            <button type="button" class="cancel" @onclick="Cancelar">Cancelar</button>

            @if (FormularioBloqueado)
            {
                <button type="button" class="confirm" @onclick="IniciarEdicao">Habilitar edicao</button>
            }
            else
            {
                <button type="button" class="confirm" @onclick="DescartarEdicao">Desfazer</button>
            }

            <button type="submit" class="btn-primary" disabled="@(!PodeSalvar || salvando)">Salvar alteracoes</button>
        </div>
    </EditForm>
</main>

@code {
    private const string MeusAnimaisRoute = "/MeusAnimais";

    private AnimalDTO animal = new();
    private AnimalDTO animalOriginal = new();
    private List<EspecieOutputDTO> especies = new();
    private List<TamanhoAnimalDTO> tamanhos = new();
    private bool edicaoHabilitada;
    private bool tentouSalvar;
    private bool salvando;
    private string? mensagemErro;

    [Parameter]
    public int id { get; set; }

    private bool FormularioBloqueado => !edicaoHabilitada || salvando;
    private bool PodeSalvar => edicaoHabilitada && CamposObrigatoriosPreenchidos && HouveAlteracao;
    private bool CamposObrigatoriosPreenchidos => !string.IsNullOrWhiteSpace(animal.Nome) && animal.EspecieId > 0 && animal.TamanhoAnimalId > 0;
    private bool HouveAlteracao => animal.Nome != animalOriginal.Nome
        || animal.EspecieId != animalOriginal.EspecieId
        || animal.Raca != animalOriginal.Raca
        || animal.Idade != animalOriginal.Idade
        || animal.FotoDataUrl != animalOriginal.FotoDataUrl
        || animal.TamanhoAnimalId != animalOriginal.TamanhoAnimalId;
    private bool ExibirErroNome => tentouSalvar && string.IsNullOrWhiteSpace(animal.Nome);
    private bool ExibirErroEspecie => tentouSalvar && animal.EspecieId <= 0;
    private bool ExibirErroTamanho => tentouSalvar && animal.TamanhoAnimalId <= 0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarFormularioAsync();
    }

    private async Task CarregarFormularioAsync()
    {
        animal = await AnimalService.GetById(id);
        animalOriginal = ClonarAnimal(animal);
        especies = await EspecieService.GetAllAsync();
        tamanhos = await TamanhoAnimalService.GetAllAsync();
    }

    private void IniciarEdicao()
    {
        edicaoHabilitada = true;
        LimparEstadoDeValidacao();
    }

    private void DescartarEdicao()
    {
        animal = ClonarAnimal(animalOriginal);
        edicaoHabilitada = false;
        LimparEstadoDeValidacao();
    }

    private void Cancelar()
    {
        if (edicaoHabilitada)
        {
            DescartarEdicao();
            return;
        }

        Navigation.NavigateTo(MeusAnimaisRoute);
    }

    private async Task SalvarAlteracoes()
    {
        tentouSalvar = true;
        mensagemErro = null;

        if (!PodeSalvar)
        {
            if (!CamposObrigatoriosPreenchidos)
            {
                mensagemErro = "Preencha os campos obrigatorios antes de salvar.";
            }

            return;
        }

        salvando = true;
        var alteracaoSalva = await AnimalService.Editar(animal);
        salvando = false;

        if (!alteracaoSalva)
        {
            mensagemErro = "Nao foi possivel salvar as alteracoes agora.";
            return;
        }

        animalOriginal = ClonarAnimal(animal);
        edicaoHabilitada = false;
        LimparEstadoDeValidacao();
        await DeviceFeedbackService.VibrateSuccessAsync();
        Navigation.NavigateTo(MeusAnimaisRoute);
    }

    private async Task SelecionarFotoAsync(InputFileChangeEventArgs args)
    {
        if (args.FileCount == 0)
        {
            return;
        }

        var file = args.File;
        await using var fileStream = file.OpenReadStream(5 * 1024 * 1024);
        using var memoryStream = new MemoryStream();
        await fileStream.CopyToAsync(memoryStream);

        var imageBytes = memoryStream.ToArray();
        animal.FotoDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(imageBytes)}";
        await DeviceFeedbackService.VibrateSelectionAsync();
    }

    private async Task RemoverFotoAsync()
    {
        animal.FotoDataUrl = null;
        await DeviceFeedbackService.VibrateWarningAsync();
    }

    private void LimparEstadoDeValidacao()
    {
        tentouSalvar = false;
        mensagemErro = null;
    }

    private static AnimalDTO ClonarAnimal(AnimalDTO origem)
    {
        return new AnimalDTO
        {
            Id = origem.Id,
            Nome = origem.Nome,
            EspecieId = origem.EspecieId,
            NomeEspecie = origem.NomeEspecie,
            Raca = origem.Raca,
            Idade = origem.Idade,
            FotoDataUrl = origem.FotoDataUrl,
            TamanhoAnimalId = origem.TamanhoAnimalId,
            NomeTamanhoAnimal = origem.NomeTamanhoAnimal,
            UsuarioId = origem.UsuarioId,
            NomeUsuario = origem.NomeUsuario
        };
    }
}
