@page "/perfil/biometria"
@inject PasskeyAuthService PasskeyAuthService
@inject DeviceFeedbackService DeviceFeedbackService
@inject AuthService AuthService
@inject NavigationManager Navigation

<main>
    <section class="notification-hero">
        <p class="title">Biometria</p>
        <p class="subtitle">Cadastre uma passkey para entrar com digital, rosto ou PIN do dispositivo.</p>
    </section>

    <section class="notification-card">
        <p class="section-title">Status</p>
        <p class="section-text">Suporte no navegador: @(suportado ? "Sim" : "Nao")</p>

        @if (!string.IsNullOrWhiteSpace(mensagem))
        {
            <p class="feedback">@mensagem</p>
        }

        <button class="primary" @onclick="CadastrarBiometriaAsync" disabled="@(!suportado || carregando)">
            <span class="material-symbols-outlined">fingerprint</span>
            @(carregando ? "Abrindo biometria..." : "Cadastrar neste dispositivo")
        </button>

        <button class="logout" @onclick="SairAsync" disabled="@carregando">
            <span class="material-symbols-outlined">logout</span>
            Sair
        </button>
    </section>

    <section class="notification-card">
        <p class="section-title">Dispositivos cadastrados</p>

        @if (credenciais.Count == 0)
        {
            <p class="section-text">Nenhuma biometria cadastrada ainda.</p>
        }
        else
        {
            @foreach (var credencial in credenciais)
            {
                <div class="button-group">
                    <div>
                        <p class="section-text">@credencial.FriendlyName</p>
                        <p class="helper-text">Criado em @credencial.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        @if (credencial.LastUsedAt.HasValue)
                        {
                            <p class="helper-text">Ultimo uso em @credencial.LastUsedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        }
                    </div>

                    <button class="secondary" @onclick="() => RemoverBiometriaAsync(credencial.Id)" disabled="@carregando">
                        Remover
                    </button>
                </div>
            }
        }
    </section>
</main>

<MenuInferior />

@code {
    private bool suportado;
    private bool carregando;
    private string? mensagem;
    private List<PasskeyCredentialDTO> credenciais = new();

    protected override async Task OnInitializedAsync()
    {
        suportado = await PasskeyAuthService.IsSupportedAsync();
        await CarregarCredenciaisAsync();
    }

    private async Task CadastrarBiometriaAsync()
    {
        carregando = true;
        mensagem = null;

        var resultado = await PasskeyAuthService.RegisterCurrentDeviceAsync();
        mensagem = resultado.Message;

        if (resultado.Success)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
            await CarregarCredenciaisAsync();
        }
        else
        {
            await DeviceFeedbackService.VibrateWarningAsync();
        }

        carregando = false;
    }

    private async Task RemoverBiometriaAsync(int credentialId)
    {
        carregando = true;
        mensagem = null;

        var resultado = await PasskeyAuthService.RemoveCredentialAsync(credentialId);
        mensagem = resultado.Message;

        if (resultado.Success)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
            await CarregarCredenciaisAsync();
        }
        else
        {
            await DeviceFeedbackService.VibrateWarningAsync();
        }

        carregando = false;
    }

    private async Task CarregarCredenciaisAsync()
    {
        credenciais = await PasskeyAuthService.GetMyCredentialsAsync();
    }

    private async Task SairAsync()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}
