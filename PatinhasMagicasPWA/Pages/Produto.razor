@page "/produto"
@inject NavigationManager Navigation
@inject ProdutoService ProdutoService

<main>
    <section id="product-section">
        <div class="title-product">
            <ul>
                <li>
                    <p>Nossos Produtos</p>
                    <p>As melhores ofertas para seu pet</p>
                </li>
            </ul>
        </div>

        <div class="card-product-bg">
            <button class="card-product">
                <div class="img-card">
                    <img src="./img/product-accessories.jpg" alt="Ração Patinhas Mágicas" />
                    <p>
                        Acessórios
                    </p>
                </div>
            </button>

            <div class="left">
                <button class="card-product">
                    <div class="img-card">
                        <img src="./img/product-food.jpg" alt="Ração Patinhas Mágicas" />
                        <p>Racão</p>
                    </div>
                </button>

                <button class="card-product">
                    <div class="img-card">
                        <img src="./img/product-toys.jpg" alt="Ração Patinhas Mágicas" />
                        <p>
                            Brinquedos
                        </p>
                    </div>
                </button>
            </div>
        </div>

    </section>

    <section id="banner-product">
        <img src="./img/banner-promocao-pet.jpg" alt="">
    </section>

    @if (produtos.Count == 0)
    {
        <p>Não há produtos disponíveis no momento.</p>
    }
    else
    {
        <section id="carousel-product">
            <div id="carouselExample" class="carousel slide">
                <div class="carousel-inner">
                    @foreach (var produto in produtos)
                    {
                        <div class="carousel-item @(produto == produtos.First() ? "active" : "")">
                            <img src="@produto.UrlImagem" class="d-block w-100" alt="@produto.Nome" />
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                        data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                        data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </section>
    }

  
    @if (produtos.Count == 0)
    {
        <p>Não há produtos disponíveis no momento.</p>
    }
    else
    {
        <section id="card-product">

            @foreach (var produto in produtos)
            {
                <button class="card" style="width: 18rem;">
                    <img src="@produto.UrlImagem" class="card-img-top" alt="@produto.Nome">
                    <div class="card-body">
                        <p class="card-title">@produto.Nome</p>
                        <div class="info-card">
                            <p class="card-text">Em estoque</p>
                            <p class="card-text">R$@produto.Preco</p>
                        </div>
                    </div>
                </button>
            }

        </section>
    }

</main>

<MenuInferior />

@code {
    List<ProdutoDTO> produtos = new();

    protected override async Task OnInitializedAsync()
    {
        produtos = await ProdutoService.GetAllProdutosAsync();
    }

}
