@page "/Cadastro"
@layout NoMenuLayout
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@inject UsuarioService UsuarioService
@inject IJSRuntime JS

<main class="login-page">
    <div id="container-title-logo">
        <ul>
            <li>
                <p>Cadastro</p>
            </li>
        </ul>
        <img src="./img/logo.png" alt="Patinhas Magicas" />
    </div>

    <div id="cont-form">
        <EditForm Model="@usuario" OnValidSubmit="Cadastrar">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrWhiteSpace(mensagemGeral))
            {
                <p class="mensagem-geral">@mensagemGeral</p>
            }

            <ul>
                <li>
                    <p>Nome</p>
                    <InputText @bind-Value="usuario.Nome" placeholder="Digite seu nome" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.Nome)" />
                </li>

                <li>
                    <p>CPF</p>
                    <InputText id="cpfInput" @bind-Value="usuario.CPF" placeholder="Digite CPF no formato 999.999.999-99" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.CPF)" />
                </li>

                <li>
                    <p>Email</p>
                    <InputText @bind-Value="usuario.Email" type="email" placeholder="Digite seu email" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.Email)" />
                </li>

                <li>
                    <p>DDD</p>
                    <InputNumber @bind-Value="usuario.Ddd" placeholder="Digite o DDD" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.Ddd)" />
                </li>

                <li>
                    <p>Telefone</p>
                    <InputText @bind-Value="usuario.Telefone" type="tel" placeholder="Digite seu telefone" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.Telefone)" />
                </li>

                <li>
                    <p>Senha</p>
                    <InputText @bind-Value="usuario.Senha" type="password" placeholder="Digite sua senha" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.Senha)" />
                </li>

                <li>
                    <p>Confirme sua senha</p>
                    <InputText @bind-Value="usuario.ConfirmarSenha" type="password" placeholder="Digite novamente" />
                    <ValidationMessage class="text-danger" For="@(() => usuario.ConfirmarSenha)" />
                </li>
            </ul>

            <div class="btn-cadastrar">
                <button type="submit" disabled="@carregando">
                    @(carregando ? "Cadastrando..." : "Cadastrar")
                </button>
                <button type="button" @onclick="VoltarParaAuth" disabled="@carregando">Cancelar</button>
            </div>
        </EditForm>
    </div>
</main>

@code {
    private CadastroUsuarioDTO usuario = new();
    private string? mensagemGeral;
    private bool carregando;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("aplicarMascaraCPF", "cpfInput");
        }
    }

    private void VoltarParaAuth()
    {
        Navigation.NavigateTo("/");
    }

    private async Task Cadastrar()
    {
        if (carregando)
            return;

        carregando = true;
        mensagemGeral = null;

        var usuarioDto = new UsuarioDTO
        {
            Nome = usuario.Nome!,
            CPF = usuario.CPF!,
            Email = usuario.Email!,
            Senha = usuario.Senha!,
            Ddd = usuario.Ddd!.Value,
            Telefone = usuario.Telefone!,
            TipoUsuarioId = null
        };

        var result = await UsuarioService.Cadastrar(usuarioDto);

        carregando = false;

        if (result)
        {
            Navigation.NavigateTo("/Login");
            return;
        }

        mensagemGeral = "Nao foi possivel concluir o cadastro.";
    }

}
